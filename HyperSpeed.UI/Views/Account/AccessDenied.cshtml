@{
    ViewData["Title"] = "Acesso Negado";
}

<div class="login-page">

    <div class="login-card access-card">

        <div class="access-icon">
            🚫
        </div>

        <h1>Acesso Negado</h1>

        <p>
            Você não possui permissão para acessar esta página.
        </p>

        <div class="access-buttons">

            <a asp-controller="Home"
                   asp-action="Index"
                   class="admin-btn">

                Voltar para Home

            </a>

            <a asp-controller="Usuario"
                   asp-action="Login"
                   class="btn-editar">

                Fazer Login

            </a>

        </div>

    </div>

</div>