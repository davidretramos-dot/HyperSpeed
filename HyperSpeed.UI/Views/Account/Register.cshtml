@{
    ViewData["Title"] = "Criar Conta";
}
<div class="login-page">

    <div class="login-card">

        <h1>Criar Conta</h1>

        <form asp-action="Registrar" method="post">

            <label>Nome Completo</label>
            <input type="text" name="Nome" placeholder="Digite seu nome" required />

            <label>E-mail</label>
            <input type="email" name="Email" placeholder="Digite seu e-mail" required />

            <label>CPF</label>
            <input type="text" name="Cpf" placeholder="000.000.000-00" required />

            <label>Telefone</label>
            <input type="text" name="Telefone" placeholder="(00) 00000-0000" required />

            <label>Senha</label>
            <input type="password" name="Senha" placeholder="Digite sua senha" required />

            <label>Confirmar Senha</label>
            <input type="password" name="ConfirmarSenha" placeholder="Confirme sua senha" required />

            <button type="submit">
                Criar Conta
            </button>

        </form>

        <div class="login-links">

            <a asp-controller="Login" asp-action="Index">
                Já possui uma conta?
            </a>

            <a asp-controller="Home" asp-action="Index">
                Voltar à loja
            </a>

        </div>

    </div>

</div>