                    <td>Hardware</td>

                    <td>—</td>

                    <td>54</td>

                    <td>

                        <a asp-action="Edit"
                           class="btn-editar">

                            Editar

                        </a>

                        <a asp-action="Delete"
                           class="btn-excluir">

                            Excluir

                        </a>

