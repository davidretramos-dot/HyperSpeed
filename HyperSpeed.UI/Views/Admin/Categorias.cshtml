@{
    ViewData["Title"] = "Gerenciar Categorias";
}

<div class="admin">

    <aside class="admin-sidebar">

        <h2>ADMIN</h2>

        <a asp-controller="Admin" asp-action="Index">Dashboard</a>

        <a asp-controller="ProdutoAdmin" asp-action="Index">Produtos</a>

        <a asp-controller="Categoria" asp-action="Index">Categorias</a>

        <a asp-controller="Pedido" asp-action="Index">Pedidos</a>

        <a asp-controller="Usuario" asp-action="Index">Usuários</a>

        <a asp-controller="Home" asp-action="Index">Voltar ao Site</a>

    </aside>

    <main class="admin-content">

        <div class="admin-header">

            <h1>Categorias</h1>

            <a asp-action="Create" class="admin-btn">

                + Nova Categoria

            </a>

        </div>

        <div class="admin-search">

            <input type="text"
                   placeholder="Pesquisar categoria...">

        </div>

