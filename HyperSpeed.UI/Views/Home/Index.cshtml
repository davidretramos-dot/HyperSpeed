@{
    ViewData["Title"] = "Home";
}
<link rel="stylesheet" href="/css/style.css">
<header>

    <div class="top-bar">

        <div class="logo">
            <img src="~/images/logo.png" alt="Logo">
            </div>

            <div class="search">
                <input type="text" placeholder="Pesquisa">
            </div>

            <div class="account">
                CONTA ★ FAVORITOS
            </div>

        </div>

    </header>

    <nav class="navbar">

        <div class="menu-categorias">

            <button class="hamburger">
                ☰
            </button>

            <div class="categorias-dropdown">

                <a href="#">Processadores</a>
                <a href="#">Placas de Vídeo</a>
                <a href="#">Memórias RAM</a>
                <a href="#">SSD</a>
                <a href="#">Gabinetes</a>
                <a href="#">Monitores</a>

            </div>

        </div>

        <a href="#">Carrinho</a>
        <a href="#">Monte seu PC</a>
        <a href="#">Departamentos</a>
        <a href="#">Periféricos</a>
        <a href="#">Promoções</a>

    </nav>

    <section class="banner">

        <img src="~/images/banner.jpg" alt="Banner">

        </section>

        <section class="slogan">

            <p>Tudo do bom e mais barato</p>

            <h1>CONFIRA!</h1>

        </section>

        <section class="categoria">

            <h2>MONTE SEU PC</h2>

            <div class="produtos">

                <div class="produto-card">
                    <img src="~/images/produtos/cpu-amd.png">
                        <span>R$ 1.999</span>
                    </div>

                    <div class="produto-card">
                        <img src="~/images/produtos/gpu.png">
                            <span>R$ 3.999</span>
                        </div>

                        <div class="produto-card">
                            <img src="~/images/produtos/ssd.png">
                                <span>R$ 499</span>
                            </div>

                            <div class="produto-card">
                                <img src="~/images/produtos/cpu-intel.png">
                                    <span>R$ 1.799</span>
                                </div>

                            </div>

                        </section>

                        <section class="categoria">

                            <h2>PERIFÉRICOS / OUTROS</h2>

                            <div class="produtos">

                                <div class="produto-card">
                                    <img src="~/images/produtos/teclado.png">
                                        <span>R$ 399</span>
                                    </div>

                                    <div class="produto-card">
                                        <img src="~/images/produtos/headset.png">
                                            <span>R$ 299</span>
                                        </div>

                                        <div class="produto-card">
                                            <img src="~/images/produtos/mouse.png">
                                                <span>R$ 199</span>
                                            </div>

                                            <div class="produto-card">
                                                <img src="~/images/produtos/monitor.png">
                                                    <span>R$ 1.299</span>
                                                </div>

                                            </div>

                                        </section>