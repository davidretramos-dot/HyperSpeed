@{
    ViewData["Title"] = "Produtos";
}

<link rel="stylesheet" href="css/style.css">

<link rel="stylesheet" href="/css/style.css">
<header>

    <div class="top-bar">

        <div class="logo">
            <img src="~/images/logo.png" alt="Logo">
            </div>

            <div class="search">
                <input type="text" placeholder="Pesquisa">
            </div>

            <div class="account">
                CONTA ★ FAVORITOS
            </div>

        </div>

    </header>

    <nav class="navbar">

        <div class="menu-categorias">

            <button class="hamburger">
                ☰
            </button>

            <div class="categorias-dropdown">

                <a href="#">Processadores</a>
                <a href="#">Placas de Vídeo</a>
                <a href="#">Memórias RAM</a>
                <a href="#">SSD</a>
                <a href="#">Gabinetes</a>
                <a href="#">Monitores</a>

            </div>

        </div>

        <a href="#">Carrinho</a>
        <a href="#">Monte seu PC</a>
        <a href="#">Departamentos</a>
        <a href="#">Periféricos</a>
        <a href="#">Promoções</a>

    </nav>

    <section class="categoria">

        <h2>CATÁLOGO DE PRODUTOS</h2>

        <div class="produtos">

            <div class="produto-card">
                <img src="~/images/produtos/cpu-amd.png" alt="">
                    <h3>Ryzen 7 7700X</h3>
                    <span>R$ 1.999,90</span>
                    <button>Comprar</button>
                </div>

                <div class="produto-card">
                    <img src="~/images/produtos/gpu.png" alt="">
                        <h3>RTX 4070</h3>
                        <span>R$ 4.299,90</span>
                        <button>Comprar</button>
                    </div>

                    <div class="produto-card">
                        <img src="~/images/produtos/ssd.png" alt="">
                            <h3>SSD NVMe 1TB</h3>
                            <span>R$ 499,90</span>
                            <button>Comprar</button>
                        </div>

                        <div class="produto-card">
                            <img src="~/images/produtos/placamae.png" alt="">
                                <h3>Placa Mãe B650</h3>
                                <span>R$ 1.299,90</span>
                                <button>Comprar</button>
                            </div>

                            <div class="produto-card">
                                <img src="~/images/produtos/teclado.png" alt="">
                                    <h3>Teclado Mecânico</h3>
                                    <span>R$ 329,90</span>
                                    <button>Comprar</button>
                                </div>

                                <div class="produto-card">
                                    <img src="~/images/produtos/headset.png" alt="">
                                        <h3>Headset Gamer</h3>
                                        <span>R$ 259,90</span>
                                        <button>Comprar</button>
                                    </div>

                                    <div class="produto-card">
                                        <img src="~/images/produtos/mouse.png" alt="">
                                            <h3>Mouse RGB</h3>
                                            <span>R$ 169,90</span>
                                            <button>Comprar</button>
                                        </div>

                                        <div class="produto-card">
                                            <img src="~/images/produtos/monitor.png" alt="">
                                                <h3>Monitor 27"</h3>
                                                <span>R$ 1.149,90</span>
                                                <button>Comprar</button>
                                            </div>

                                        </div>

                                    </section>